{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "installCommand": "npm install --prefix \"auto payment/donate-easy-main\"",
  "buildCommand": "npm run build --prefix \"auto payment/donate-easy-main\"",
  "outputDirectory": "auto payment/donate-easy-main/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
